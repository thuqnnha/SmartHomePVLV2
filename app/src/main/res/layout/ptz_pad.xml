<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ptzPad"
    android:layout_width="160dp"
    android:layout_height="160dp"
    android:layout_alignParentEnd="true"
    android:layout_alignParentBottom="true"
    android:layout_marginBottom="2000dp"
    android:layout_margin="24dp"
    android:background="@drawable/bg_ptz_circle"
    android:visibility="gone">

    <ImageButton
        android:id="@+id/btnUpp"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_centerHorizontal="true"
        android:layout_alignParentTop="true"
        android:src="@drawable/ic_arrow_up"
        android:background="@drawable/btn_ptz_effect"
        app:tint="#FFFFFF"/>

    <ImageButton
        android:id="@+id/btnDownn"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_centerHorizontal="true"
        android:layout_alignParentBottom="true"
        android:src="@drawable/ic_arrow_down"
        android:background="@drawable/btn_ptz_effect"
        app:tint="#FFFFFF"/>

    <ImageButton
        android:id="@+id/btnLeftt"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_centerVertical="true"
        android:layout_alignParentStart="true"
        android:src="@drawable/ic_arrow_left"
        android:background="@drawable/btn_ptz_effect"
        app:tint="#FFFFFF"/>

    <ImageButton
        android:id="@+id/btnRightt"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_centerVertical="true"
        android:layout_alignParentEnd="true"
        android:src="@drawable/ic_arrow_right"
        android:background="@drawable/btn_ptz_effect"
        app:tint="#FFFFFF"/>

    <!-- Nút trung tâm nếu cần -->
    <ImageView
        android:id="@+id/ptzDot"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_centerInParent="true"
        android:src="@drawable/ic_dot"
        android:alpha="0.3"/>
</RelativeLayout>
